{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "usuarios-cluster",
        "Match": { "Path": "/api/auth/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "usuarios-route": {
        "ClusterId": "usuarios-cluster",
        "Match": { "Path": "/api/usuarios/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api/usuarios" } ]
      },
      "pedidos-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/pedidos/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api/pedidos" } ]
      },
      "pagos-route": {
        "ClusterId": "pagos-cluster",
        "Match": { "Path": "/api/pagos/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api/pagos" } ]
      }
    },
    "Clusters": {
      "usuarios-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://usuarios:3001" }
        }
      },
      "pedidos-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://pedidos:3002" }
        }
      },
      "pagos-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://pagos:3003" }
        }
      }
    }
  }
}
