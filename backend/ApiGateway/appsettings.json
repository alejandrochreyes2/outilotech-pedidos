{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "usuarios-cluster",
        "Match": { "Path": "/api/auth/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "usuarios-route": {
        "ClusterId": "usuarios-cluster",
        "Match": { "Path": "/api/usuarios/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api/usuarios" } ]
      },
      "pedidos-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/pedidos/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api/pedidos" } ]
      },
      "pagos-route": {
        "ClusterId": "pagos-cluster",
        "Match": { "Path": "/api/pagos/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api/pagos" } ]
      },
      "chatbot-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/chatbot/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "productos-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/productos/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "productos-exact-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/productos" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "webhook-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/webhook/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "webhook-direct-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/webhook/{**remainder}" }
      },
      "sync-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/sync/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "jhon-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/jhon/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "historial-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/historial/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "facturacion-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/facturacion/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "facturacion-exact-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/facturacion" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "scan-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/scan/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "inventario-imagen-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/inventario-imagen/{**remainder}" },
        "Transforms": [ { "PathPattern": "/scan/inventario-por-imagen/{**remainder}" } ]
      },
      "pos-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/pos/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "inventario-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/inventario/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "jhonia-route": {
        "ClusterId": "pedidos-cluster",
        "Match": { "Path": "/api/jhonia/{**remainder}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      }
    },
    "Clusters": {
      "usuarios-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://usuarios:3001" }
        }
      },
      "pedidos-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://pedidos:3002" }
        }
      },
      "pagos-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://pagos:3003" }
        }
      }
    }
  }
}
