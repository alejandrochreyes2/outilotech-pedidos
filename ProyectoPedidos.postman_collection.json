            "url": { "raw": "{{base}}/api/usuarios/auth/login", "host": ["{{base}}"], "path": ["api","usuarios","auth","login"] }
          }
        },
        {
          "name": "Registrar nuevo usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Email\": \"nuevo@toyota.com\",\n  \"Password\": \"Nuevo123!\",\n  \"Name\": \"Nuevo Usuario\"\n}"
            },
            "url": { "raw": "{{base}}/api/usuarios/auth/register", "host": ["{{base}}"], "path": ["api","usuarios","auth","register"] }
          }
        },
        {
          "name": "Ver todos los usuarios (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base}}/api/usuarios", "host": ["{{base}}"], "path": ["api","usuarios"] }
          }
        }
      ]
    },
